# ============================================================
# 한국투자증권 API Keys
# https://apiportal.koreainvestment.com 에서 발급
# ============================================================
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=00000000-00
# REAL: 실전투자, VIRTUAL: 모의투자
KIS_ENVIRONMENT=VIRTUAL

# ============================================================
# AI API Keys
# ============================================================
# Claude API (매수/매도 실행 판단)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (종목 선택 & 1차 분석 리포트)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (교차 검증 & 2차 분석)
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================
# Trading Parameters
# ============================================================
# 일일 최대 투자 금액 (원)
MAX_DAILY_CAPITAL=1000000
# 일일 최대 손실 허용 (원)
MAX_DAILY_LOSS=200000
# 종목당 최대 투자 비중 (%)
MAX_POSITION_PCT=20
# 최대 동시 보유 종목 수
MAX_POSITIONS=5

# ============================================================
# Dashboard
# ============================================================
DASHBOARD_PORT=8501
